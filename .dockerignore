# Don't ship the local scrape state or DB
data/
*.duckdb
*.duckdb.wal

# VCS + CI artifacts
.git/
.github/

# Local virtual env (the image builds its own)
.venv/

# Caches
__pycache__/
*.py[co]
.ruff_cache/
.mypy_cache/
.pytest_cache/

# Build outputs
build/
dist/
wheels/
*.egg-info/

# Editor / OS
.vscode/
.idea/
.DS_Store

# Documentation that doesn't need to be in the image
docs/
tests/

# Misc
*.md
!README.md
